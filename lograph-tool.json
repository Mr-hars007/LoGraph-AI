{
  "setup": {
    "completed": true
  },
  "telemetry": {
    "mode": "jsonl",
    "endpoint": "",
    "jsonl_path": "data/otel_logs.jsonl",
    "poll_seconds": 30,
    "lookback_seconds": 999999999
  },
  "training": {
    "negative_ratio": 1,
    "epochs": 500,
    "learning_rate": 0.05,
    "message_passing_steps": 2,
    "embedding_size": 4,
    "anomaly_threshold": 0.25,
    "failure_threshold": 0.75
  },
  "actions": [
    {
      "name": "gui-action",
      "when": {
        "type": "low_link_probability",
        "threshold": 0.25
      },
      "exec": {
        "python_script": "scripts/handle_incident.py",
        "args": [
          "{source}",
          "{target}",
          "{probability}"
        ],
        "timeout_seconds": 20
      }
    },
    {
      "name": "python-failure-handler",
      "when": {
        "type": "high_failure_probability",
        "threshold": 0.75
      },
      "exec": {
        "python_script": "scripts/handle_failure.py",
        "args": [
          "{source}",
          "{target}",
          "{failure_probability}",
          "{timestamp}"
        ],
        "timeout_seconds": 20
      }
    }
  ]
}